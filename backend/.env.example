# ==============================================================================
# LeadFlow Nexus Pro — Variáveis de Ambiente (Backend)
# ==============================================================================
# Copie este arquivo para ".env" e preencha os valores antes de iniciar o servidor.
# Em produção (Render.com), configure estes valores no painel Environment Variables.
# NÃO versione o arquivo .env com segredos reais.
# ==============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333

# ── Credenciais do Admin Master ────────────────────────────────────────────────
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=SenhaForte@2024!

# ── Sessão & Segurança ─────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=120
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15

# ── Planos / Trial ─────────────────────────────────────────────────────────────
TRIAL_DAYS=7
TRIAL_LEAD_LIMIT=25

# ── Google Places API (Prospecção) ─────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=sua_chave_google_aqui

# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────────────────
# ⚠  Token PERMANENTE (System User Token) — veja docs/WHATSAPP_SETUP_PERMANENTE.md
#
# WHATSAPP_ACCESS_TOKEN  → Token do Usuário do Sistema (nunca expira quando gerado
#                          corretamente via Meta Business Manager com um System User Admin)
# WHATSAPP_PHONE_NUMBER_ID → ID do número registrado na WABA (ex: 123456789012345)
# WHATSAPP_GRAPH_API_VERSION → Versão da Graph API (padrão: v20.0)
# WHATSAPP_SEND_DELAY_MS → Intervalo em ms entre envios em massa (padrão: 1200ms = ~50/min)
#
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_SEND_DELAY_MS=1200
